index 0000000..2e28130
--- /dev/null
+++ b/lib/core/license/license_status.dart
@@ -0,0 +1,27 @@
+/// Resolved license state for the current device, computed locally from
+/// the cached `license_configs` row. This mirrors pfm-desktop's
+/// `LicenseStatus` enum exactly so both apps reason about a farm's
+/// subscription the same way.
+enum LicenseStatus {
+  /// No `license_configs` row exists yet — a brand-new install that
+  /// hasn't completed its first login. Not blocked; the trial is
+  /// registered right after the first successful sign-in.
+  firstLaunch,
+
+  /// Within the trial/subscription window, or within the 10-day offline
+  /// tolerance window past expiry. Full access.
+  valid,
+
+  /// Past expiry by 1-5 days. Full access, but a persistent banner nags
+  /// the farm owner to renew.
+  softLocked,
+
+  /// Past expiry by more than 5 days. The app is fully locked out of
+  /// farm data until the subscription is renewed.
+  hardLocked,
+
+  /// The device clock appears to have been rolled backwards relative to
+  /// the last recorded usage timestamp, beyond a small tolerance. Locked
+  /// out as an anti-tamper measure, independent of trial expiry.
+  clockTampered,
+}
diff --git a/lib/core/license/license_watcher.dart b/lib/core/license/license_watcher.dart
new file mode 100644
index 0000000..052468b
--- /dev/null
+++ b/lib/core/license/license_watcher.dart
@@ -0,0 +1,47 @@
+import 'dart:async';
+
+import 'license_service.dart';
+import 'license_status.dart';
+
+/// Polls the farm's subscription status every 6 hours while the app is
+/// running, mirroring pfm-desktop's `main_scaffold.dart` Timer.periodic
+/// cadence. [onStatusChanged] fires whenever the resolved status is
+/// anything other than [LicenseStatus.valid] — hard-locked,
+/// clock-tampered, or soft-locked — so the host widget can react
+/// (force-navigate to lockout, or show a renewal banner) without this
+/// class knowing anything about navigation or UI.
+class LicenseWatcher {
+  LicenseWatcher({
+    required this.licenseService,
+    required this.hardwareId,
+    required this.onStatusChanged,
+    this.pollInterval = const Duration(hours: 6),
+  });
+
+  final LicenseService licenseService;
+  final String hardwareId;
+  final void Function(LicenseStatus status) onStatusChanged;
+  final Duration pollInterval;
+
+  Timer? _timer;
+
+  void start() {
+    _timer = Timer.periodic(pollInterval, (_) => _check());
+  }
+
+  void dispose() {
+    _timer?.cancel();
+  }
+
+  Future<void> _check() async {
+    try {
+      await licenseService.renewFromCloud(hardwareId);
+      final status = await licenseService.checkLicense();
+      if (status != LicenseStatus.valid) {
+        onStatusChanged(status);
+      }
+    } catch (_) {
+      // ignore network errors, identical to SessionWatcher
+    }
+  }
+}
