diff --git a/lib/core/license/device_fingerprint.dart b/lib/core/license/device_fingerprint.dart
new file mode 100644
index 0000000..e7a157e
--- /dev/null
+++ b/lib/core/license/device_fingerprint.dart
@@ -0,0 +1,29 @@
+import 'dart:io' show Platform;
+
+import 'package:device_info_plus/device_info_plus.dart';
+
+/// Mobile equivalent of pfm-desktop's `getDeviceHardwareId()`. This is
+/// deliberately a real OS-level identifier rather than an app-generated
+/// random ID (which is what `DeviceIdentityStore` provides for the sales
+/// queue) — a license trial must not be trivially resettable by simply
+/// uninstalling and reinstalling the app.
+Future<String> getDeviceHardwareId() async {
+  final deviceInfo = DeviceInfoPlugin();
+  try {
+    if (Platform.isAndroid) {
+      final info = await deviceInfo.androidInfo;
+      // info.id is the build fingerprint — stable per device/ROM install.
+      return 'android-${info.id}';
+    }
+    if (Platform.isIOS) {
+      final info = await deviceInfo.iosInfo;
+      final vendorId = info.identifierForVendor;
+      if (vendorId != null && vendorId.isNotEmpty) {
+        return 'ios-$vendorId';
+      }
+    }
+  } catch (_) {
+    // Fall through to the unknown placeholder below.
+  }
+  return 'unknown-hardware-id';
+}
