+class LicenseConfig {
+  const LicenseConfig({
+    required this.mode,
+    required this.farmId,
+    required this.userId,
+    required this.hardwareId,
+    required this.installedAt,
+    required this.expiresAt,
+    required this.lastUsed,
+    required this.lastCloudCheckAt,
+  });
+
+  final String mode;
+  final String? farmId;
+  final String? userId;
+  final String? hardwareId;
+  final DateTime installedAt;
+  final DateTime expiresAt;
+  final DateTime lastUsed;
+  final DateTime? lastCloudCheckAt;
+
+  factory LicenseConfig.fromMap(Map<String, Object?> map) {
+    return LicenseConfig(
+      mode: map['mode'] as String? ?? 'OFFLINE',
+      farmId: map['farm_id'] as String?,
+      userId: map['user_id'] as String?,
+      hardwareId: map['hardware_id'] as String?,
+      installedAt: DateTime.parse(map['installed_at'] as String),
+      expiresAt: DateTime.parse(map['expires_at'] as String),
+      lastUsed: DateTime.parse(map['last_used'] as String),
+      lastCloudCheckAt: map['last_cloud_check_at'] == null
+          ? null
+          : DateTime.parse(map['last_cloud_check_at'] as String),
+    );
+  }
+}
diff --git a/lib/core/license/license_service.dart b/lib/core/license/license_service.dart
new file mode 100644
index 0000000..6eb3761
--- /dev/null
+++ b/lib/core/license/license_service.dart
@@ -0,0 +1,212 @@
+import '../storage/local_database.dart';
+import '../../features/auth/data/supabase_remote_api.dart';
+import 'license_config.dart';
+import 'license_status.dart';
+
+/// Mobile port of pfm-desktop's `LicenseService`. Both apps defer to the
+/// SAME `register_device_trial` / `get_device_subscription_status` RPCs,
+/// keyed by `farm_id` on the server side — so starting the trial on
+/// mobile and starting it on desktop draw from the exact same 30-day
+/// clock for a given farm. This class only ever EXTENDS the locally
+/// cached `expires_at`; the server result is the source of truth, never
+/// a client-side guess.
+///
+/// Grace logic mirrors desktop exactly:
+///   1. now < expiresAt                                -> valid
+///   2. now < lastUsed - 2min                           -> clockTampered
+///   3. daysSince(lastCloudCheckAt) < 10                -> valid (offline tolerance)
+///   4. daysPastExpiry <= 5                             -> softLocked
+///   5. else                                            -> hardLocked
+class LicenseService {
+  LicenseService({
+    required LocalDatabase localDatabase,
+    required SupabaseRemoteApi remoteApi,
+  }) : _localDatabase = localDatabase,
+       _remoteApi = remoteApi;
+
+  final LocalDatabase _localDatabase;
+  final SupabaseRemoteApi _remoteApi;
+
+  static const _clockTamperTolerance = Duration(minutes: 2);
+  static const _offlineToleranceDays = 10;
+  static const _softLockGraceDays = 5;
+
+  Future<LicenseStatus> checkLicense() async {
+    final config = await getConfig();
+    if (config == null) {
+      return LicenseStatus.firstLaunch;
+    }
+
+    final now = DateTime.now();
+
+    if (now.isBefore(config.lastUsed.subtract(_clockTamperTolerance))) {
+      return LicenseStatus.clockTampered;
+    }
+
+    if (now.isBefore(config.expiresAt)) {
+      return LicenseStatus.valid;
+    }
+
+    final lastCheck = config.lastCloudCheckAt;
+    if (lastCheck != null && now.difference(lastCheck).inDays < _offlineToleranceDays) {
+      return LicenseStatus.valid;
+    }
+
+    final daysPastExpiry = now.difference(config.expiresAt).inDays;
+    if (daysPastExpiry <= _softLockGraceDays) {
+      return LicenseStatus.softLocked;
+    }
+
+    await _localDatabase.updateLicenseConfigFields({'mode': 'HARD_LOCKED'});
+    return LicenseStatus.hardLocked;
+  }
+
+  /// Call once after every successful login/signup. Safe to call
+  /// repeatedly — if this farm already has a trial or subscription
+  /// running (from desktop, web, or a previous mobile install), the RPC
+  /// returns that existing expiry and nothing changes except the
+  /// device_registrations link for this hardware ID.
+  ///
+  /// Fails open: if the server call doesn't succeed (no network, RPC
+  /// missing, etc.), grants a local 30-day fallback so a worker with no
+  /// signal isn't blocked from ever starting the app. The next
+  /// successful [renewFromCloud] call will reconcile this with the
+  /// server's real value.
+  Future<String?> initTrialFromCloud({
+    required String userId,
+    required String farmId,
+    required String hardwareId,
+  }) async {
+    if (!_remoteApi.isConfigured) {
+      await _fallbackInit(userId: userId, farmId: farmId, hardwareId: hardwareId);
+      return null;
+    }
+
+    try {
+      final data = await _remoteApi.registerDeviceTrial(
+        userId: userId,
+        farmId: farmId,
+        hardwareId: hardwareId,
+      );
+
+      if (data['success'] != true) {
+        await _fallbackInit(userId: userId, farmId: farmId, hardwareId: hardwareId);
+        return data['error']?.toString();
+      }
+
+      final expiresAt = _parseExpiry(data['license_expires_at']);
+      await _localDatabase.upsertLicenseConfig(
+        mode: 'CLOUD_TRIAL',
+        farmId: farmId,
+        userId: userId,
+        hardwareId: hardwareId,
+        installedAt: DateTime.now(),
+        expiresAt: expiresAt,
+        lastCloudCheckAt: DateTime.now(),
+      );
+      return null;
+    } catch (_) {
+      await _fallbackInit(userId: userId, farmId: farmId, hardwareId: hardwareId);
+      return null;
+    }
+  }
+
+  Future<void> _fallbackInit({
+    required String userId,
+    required String farmId,
+    required String hardwareId,
+  }) async {
+    final existing = await getConfig();
+    if (existing != null) {
+      // Already has a local clock running (e.g. from a previous online
+      // registration) — don't clobber it just because this attempt was
+      // offline.
+      return;
+    }
+    await _localDatabase.upsertLicenseConfig(
+      mode: 'CLOUD_TRIAL',
+      farmId: farmId,
+      userId: userId,
+      hardwareId: hardwareId,
+      installedAt: DateTime.now(),
+      expiresAt: DateTime.now().add(const Duration(days: 30)),
+      lastCloudCheckAt: null,
+    );
+  }
+
+  /// Call on every boot (when online) and every 6 hours while running,
+  /// via [LicenseWatcher]. Only ever extends the locally cached
+  /// `expires_at` — never shortens it client-side based on a clock
+  /// reading alone.
+  Future<void> renewFromCloud(String hardwareId) async {
+    if (!_remoteApi.isConfigured) {
+      return;
+    }
+    try {
+      final data = await _remoteApi.getDeviceSubscriptionStatus(hardwareId);
+      if (data == null || data['success'] != true) {
+        return;
+      }
+
+      final config = await getConfig();
+      if (config == null) {
+        return;
+      }
+
+      final now = DateTime.now();
+      final updates = <String, Object?>{
+        'last_used': now.toIso8601String(),
+        'last_cloud_check_at': now.toIso8601String(),
+      };
+
+      final serverExpiry = data['license_expires_at'] != null
+          ? _parseExpiry(data['license_expires_at'])
+          : null;
+      if (serverExpiry != null && serverExpiry.isAfter(config.expiresAt)) {
+        updates['expires_at'] = serverExpiry.toIso8601String();
+      }
+
+      final serverStatus = data['license_status']?.toString();
+      if (serverStatus != null) {
+        updates['mode'] = _serverStatusToLocalMode(serverStatus);
+      }
+
+      await _localDatabase.updateLicenseConfigFields(updates);
+    } catch (_) {
+      // Offline or RPC failure — silently skip, identical to desktop.
+    }
+  }
+
+  /// Call on every local database write. Cheap, fire-and-forget,
+  /// swallows its own errors — used as the anti-clock-tamper heartbeat.
+  Future<void> touchLastUsed() => _localDatabase.touchLicenseLastUsed();
+
+  Future<LicenseConfig?> getConfig() async {
+    final row = await _localDatabase.readLicenseConfig();
+    if (row == null) {
+      return null;
+    }
+    return LicenseConfig.fromMap(row);
+  }
+
+  String _serverStatusToLocalMode(String serverStatus) {
+    switch (serverStatus) {
+      case 'ACTIVE':
+        return 'CLOUD_ACTIVE';
+      case 'EXPIRED':
+        return 'EXPIRED';
+      case 'CLOUD_TRIAL':
+        return 'CLOUD_TRIAL';
+      default:
+        return 'CLOUD_TRIAL';
+    }
+  }
+
+  DateTime _parseExpiry(Object? raw) {
+    if (raw == null) {
+      return DateTime.now().add(const Duration(days: 30));
+    }
+    return DateTime.tryParse(raw.toString()) ??
+        DateTime.now().add(const Duration(days: 30));
+  }
+}
